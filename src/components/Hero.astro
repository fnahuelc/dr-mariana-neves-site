---
interface Props {
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
}

const { title, description, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero">
  <!--
    VIDEO BACKGROUND
    1. Download from https://mixkit.co/free-stock-video/girl-meditating-in-yoga-pose-at-sunset-4803/
    2. Rename the file to: hero-video.mp4
    3. Place it in the public/ folder of this project
    The gradient below is shown as fallback until the video file is added.
  -->
  <video class="hero-video" autoplay muted loop playsinline aria-hidden="true">
    <source src={`${base}/mixkit-girl-meditating-in-yoga-pose-at-sunset-4803-hd-ready.mp4`} type="video/mp4" />
  </video>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="container hero-inner">
    <p class="eyebrow hero-eyebrow">Medicina Endocanabinóide</p>
    <h1 class="hero-title" set:html={title.replace(/\./g, '.<br>')}></h1>
    <p class="hero-sub">{description}</p>
    <div class="button-row hero-btns">
      <a class="button button-primary" href={primaryHref} target="_blank" rel="noreferrer">{primaryLabel}</a>
      <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  /* Gradient fallback shown when video hasn't loaded */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(160deg,
        rgba(10, 20, 35, 0.5) 0%,
        rgba(10, 25, 40, 0.35) 100%),
      linear-gradient(135deg,
        #1a3a50 0%,
        #2a5060 25%,
        #3a7080 50%,
        #254555 75%,
        #0d1b2a 100%);
    z-index: 0;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }

  /* On mobile portrait, show the full video (no crop) anchored to the top.
     The dark navy background (from .hero::before) fills the space below it. */
  @media (max-width: 768px) {
    .hero-video {
      object-fit: contain;
      object-position: center top;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 20, 35, 0.55);
    z-index: 2;
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    padding-bottom: 7rem;
    max-width: 780px;
  }

  /* Entrance animations — staggered on load */
  .hero-eyebrow {
    animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 50ms;
  }

  .hero-title {
    animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 160ms;
  }

  .hero-sub {
    animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 290ms;
  }

  .hero-btns {
    animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 420ms;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-title {
    margin: 1rem 0 1.2rem;
    font-family: var(--font-heading);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .hero-title :global(.accent) {
    color: var(--color-teal);
  }

  .hero-eyebrow {
    margin-bottom: 0;
  }

  .hero-sub {
    font-weight: 300;
    font-size: 1.05rem;
    color: rgba(168, 196, 184, 0.9);
    max-width: 500px;
    line-height: 1.75;
    margin: 0 0 2rem;
  }

  /* Animated scroll indicator */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    animation: slideUp 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 800ms;
  }

  .hero-scroll-hint span {
    display: block;
    width: 1.5px;
    height: 2.5rem;
    background: linear-gradient(to bottom, var(--color-teal), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(0.7); transform-origin: top; }
    50%       { opacity: 1;   transform: scaleY(1);   transform-origin: top; }
  }

  @media (max-width: 640px) {
    .hero-inner {
      padding-bottom: 6rem;
    }

    .hero-title {
      font-size: clamp(2.6rem, 14vw, 3.5rem);
    }
  }
</style>
