---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<section class="section how-section" id="como-funciona">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Como funciona</p>
      <h2 class="section-title">Um processo simples, transparente e centrado em você.</h2>
      <p class="section-lead">
        Do primeiro contato ao acompanhamento contínuo — cada etapa foi pensada para ser clara, segura e personalizada.
      </p>
    </div>

    <div class="grid grid-3 steps-grid">
      {steps.map((step, i) => (
        <article class="card step-card reveal" style={`--reveal-i: ${i}`}>
          <p class="step-number">{step.number}</p>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .how-section {
    background: var(--color-surface-muted);
  }

  .section-head {
    display: grid;
    gap: 1rem;
    margin-bottom: 2.5rem;
    max-width: 680px;
  }

  .step-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 0.8rem;
    align-content: start;
  }

  .step-card::after {
    content: '';
    position: absolute;
    inset: auto -1.5rem -1.5rem auto;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(58, 191, 173, 0.08), transparent 70%);
    pointer-events: none;
  }

  .step-number {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-teal);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .step-card h3 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .step-card p:last-child {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.75;
  }
</style>
