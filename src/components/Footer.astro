---
import { siteConfig } from '../data/site';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="eyebrow">Medicina Canabinóide</p>
      <h2>{siteConfig.brandName}</h2>
      <p class="footer-crm">{siteConfig.specialty} | {siteConfig.crm}</p>
      <p class="footer-coverage">{siteConfig.onlineCoverage}</p>
    </div>

    <div>
      <h3>Contato</h3>
      <ul>
        <li><a href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">{siteConfig.whatsappLabel}</a></li>
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li>{siteConfig.phoneDisplay}</li>
        <li>{siteConfig.contactHours}</li>
        <li><a href={siteConfig.linkedinUrl} target="_blank" rel="noreferrer">LinkedIn</a></li>
      </ul>
    </div>

    <div>
      <h3>Navegação</h3>
      <ul>
        <li><a href="#sobre">Sobre a médica</a></li>
        <li><a href="#condicoes">Tratamentos</a></li>
        <li><a href="#como-funciona">Como funciona</a></li>
        <li><a href="#faq">Perguntas frequentes</a></li>
        <li><a href="#contato">Agendar consulta</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-meta">
    <p>{siteConfig.disclaimer}</p>
    <p class="footer-note">{siteConfig.footerNote}</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 0 2.5rem;
    background: #0A1520;
    color: rgba(255, 255, 255, 0.7);
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-grid {
    display: grid;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .footer-brand {
    display: grid;
    gap: 0.5rem;
  }

  .site-footer h2 {
    margin: 0.5rem 0 0;
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .site-footer h3 {
    margin: 0 0 1rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-crm,
  .footer-coverage {
    margin: 0;
    font-size: 0.85rem;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }

  .site-footer li {
    font-size: 0.9rem;
  }

  .site-footer a {
    transition: color 0.2s;
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: var(--color-teal);
  }

  .footer-meta {
    display: grid;
    gap: 0.6rem;
    padding-top: 1.5rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-note {
    margin: 0;
  }

  @media (min-width: 800px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
      align-items: start;
    }
  }
</style>
