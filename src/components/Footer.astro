---
import { siteConfig } from '../data/site';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <p class="eyebrow">Atendimento médico online</p>
      <h2>{siteConfig.brandName}</h2>
      <p>{siteConfig.specialty} | {siteConfig.crm}</p>
    </div>

    <div>
      <h3>Contato</h3>
      <ul>
        <li><a href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">{siteConfig.whatsappLabel}</a></li>
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li>{siteConfig.phoneDisplay}</li>
        <li><a href={siteConfig.linkedinUrl} target="_blank" rel="noreferrer">LinkedIn</a></li>
      </ul>
    </div>

    <div>
      <h3>Informações</h3>
      <ul>
        <li><a href="/faq">Perguntas frequentes</a></li>
        <li><a href="/privacy-policy">Política de Privacidade</a></li>
        <li><a href="/terms">Termos de Uso</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-meta">
    <p>{siteConfig.disclaimer}</p>
    <p>{siteConfig.footerNote}</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 0 2.75rem;
    background: linear-gradient(180deg, rgba(22, 50, 74, 0.98), rgba(20, 43, 64, 1));
    color: rgba(255, 255, 255, 0.82);
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .site-footer h2,
  .site-footer h3 {
    margin: 0 0 0.75rem;
    color: #ffffff;
  }

  .site-footer h2 {
    font-family: var(--font-heading);
    font-size: 2.3rem;
    line-height: 1;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .site-footer a:hover,
  .site-footer a:focus-visible {
    color: #ffffff;
  }

  .footer-meta {
    display: grid;
    gap: 0.8rem;
    padding-top: 1.4rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.68);
  }

  @media (min-width: 800px) {
    .footer-grid {
      grid-template-columns: 1.2fr 0.8fr 0.8fr;
      align-items: start;
    }
  }
</style>