---
import { siteConfig } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section" id="sobre">
  <div class="container split about-split">
    <div class="about-image reveal">
      <img
        src={`${base}/marianamoreiraneves.png`}
        alt="Dra. Mariana Neves"
        class="doctor-photo"
      />
    </div>

    <div class="about-copy reveal" style="--reveal-i: 1">
      <p class="eyebrow">Sobre a médica</p>
      <h2 class="section-title">Ciência, escuta e cuidado individualizado.</h2>
      <p class="section-lead">{siteConfig.doctorBio}</p>
      <div class="credentials-card card">
        <p class="credentials-label">Credenciais</p>
        <p class="credentials-value">{siteConfig.doctorCredentials}</p>
        <p class="credentials-crm">{siteConfig.crm}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .about-split {
    align-items: center;
  }

  .doctor-photo {
    width: 100%;
    height: 100%;
    min-height: 28rem;
    max-height: 42rem;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    display: block;
  }

  .about-copy {
    display: grid;
    gap: 1.2rem;
    align-content: center;
  }

  .credentials-card {
    display: grid;
    gap: 0.4rem;
    max-width: 34rem;
    border-left: 3px solid var(--color-teal);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .credentials-label {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-teal);
  }

  .credentials-value {
    margin: 0;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .credentials-crm {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
