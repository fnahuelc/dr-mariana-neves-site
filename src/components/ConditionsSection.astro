---
interface Condition {
  title: string;
  description: string;
}

interface Props {
  items: Condition[];
}

const { items } = Astro.props;
---

<section class="section" id="condicoes">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Condições tratadas</p>
      <h2 class="section-title">Protocolos canabinóides para diversas condições clínicas.</h2>
      <p class="section-lead">
        Cada tratamento é personalizado após avaliação médica completa. A medicina canabinóide pode ser indicada como terapia principal ou adjuvante.
      </p>
    </div>

    <div class="grid grid-3 conditions-grid">
      {items.map((item, i) => (
        <article class="card condition-card reveal" style={`--reveal-i: ${i % 3}`}>
          <div class="condition-dot" aria-hidden="true"></div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-head {
    display: grid;
    gap: 1rem;
    margin-bottom: 2.5rem;
    max-width: 680px;
  }

  .condition-card {
    display: grid;
    gap: 0.8rem;
    align-content: start;
  }

  .condition-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-teal);
  }

  .condition-card h3 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .condition-card p {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.75;
  }
</style>
