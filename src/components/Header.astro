---
import { siteConfig } from '../data/site';

const links = [
  { href: '#sobre',          label: 'Sobre' },
  { href: '#condicoes',      label: 'Tratamentos' },
  { href: '#como-funciona',  label: 'Como Funciona' },
  { href: '#faq',            label: 'FAQ' },
];
---

<header class="site-header" id="site-header">
  <div class="container header-shell">
    <a class="brand" href="/" aria-label={`Página inicial de ${siteConfig.brandName}`}>
      <span class="brand-mark" aria-hidden="true">+</span>
      <span class="brand-text">
        <strong>{siteConfig.brandName}</strong>
        <small>{siteConfig.specialty}</small>
      </span>
    </a>

    <nav aria-label="Principal">
      <ul class="nav-list">
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <a
      class="button button-primary header-cta"
      href={siteConfig.whatsappUrl}
      target="_blank"
      rel="noreferrer"
    >
      {siteConfig.whatsappLabel}
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 1.1rem 0;
    background: rgba(13, 27, 42, 0);
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .site-header.scrolled {
    background: rgba(13, 27, 42, 0.96);
    border-bottom-color: var(--color-border-subtle);
    backdrop-filter: blur(12px);
  }

  .header-shell {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 13rem;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 4px;
    background: var(--color-teal);
    color: var(--color-bg);
    font-size: 1.3rem;
    font-weight: 800;
    font-family: var(--font-heading);
    flex-shrink: 0;
  }

  .brand-text strong {
    display: block;
    font-size: 0.95rem;
    font-family: var(--font-heading);
    color: #fff;
  }

  .brand-text small {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.25rem 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .nav-list a {
    font-size: 0.78rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 0.7rem;
    transition: color 0.2s;
  }

  .nav-list a:hover,
  .nav-list a:focus-visible {
    color: var(--color-teal);
  }

  .header-cta {
    min-width: 10rem;
  }

  @media (max-width: 940px) {
    nav {
      order: 3;
      width: 100%;
    }

    .nav-list {
      justify-content: flex-start;
    }

    .header-cta {
      margin-left: auto;
    }
  }

  @media (max-width: 640px) {
    .header-cta {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (function () {
    var header = document.getElementById('site-header');
    if (!header) return;

    function update() {
      if (window.scrollY > 60) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    }

    update();
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>
