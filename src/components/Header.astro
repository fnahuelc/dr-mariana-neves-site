---
import { siteConfig } from '../data/site';

const links = [
  { href: '/', label: 'Início' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contato' },
  { href: '/privacy-policy', label: 'Privacidade' },
  { href: '/terms', label: 'Termos' }
];
---

<header class="site-header">
  <div class="container header-shell">
    <a class="brand" href="/" aria-label={`Página inicial de ${siteConfig.brandName}`}>
      <span class="brand-mark">+</span>
      <span>
        <strong>{siteConfig.brandName}</strong>
        <small>{siteConfig.specialty}</small>
      </span>
    </a>

    <nav aria-label="Principal">
      <ul class="nav-list">
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <a class="button button-primary header-cta" href={siteConfig.whatsappUrl} target="_blank" rel="noreferrer">
      {siteConfig.whatsappLabel}
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0;
    backdrop-filter: blur(18px);
    background: rgba(248, 251, 254, 0.78);
    border-bottom: 1px solid rgba(56, 97, 128, 0.08);
  }

  .header-shell {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 14rem;
  }

  .brand strong {
    display: block;
    font-size: 1rem;
  }

  .brand small {
    display: block;
    color: var(--color-text-muted);
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, #dbeaf5, #ffffff);
    color: var(--color-primary-dark);
    font-size: 1.5rem;
    font-weight: 800;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.2rem;
    padding: 0;
    margin: 0;
    list-style: none;
    color: var(--color-text-muted);
  }

  .nav-list a:hover,
  .nav-list a:focus-visible {
    color: var(--color-primary-dark);
  }

  .header-cta {
    min-width: 11rem;
  }

  @media (max-width: 940px) {
    nav {
      order: 3;
      width: 100%;
    }

    .nav-list {
      justify-content: flex-start;
    }

    .header-cta {
      margin-left: auto;
    }
  }

  @media (max-width: 640px) {
    .header-cta {
      width: 100%;
    }
  }
</style>