---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow = 'Pronto para dar o próximo passo?',
  title,
  description,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref
} = Astro.props;
---

<section class="section-sm">
  <div class="container">
    <div class="cta-shell">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h2>{title}</h2>
        <p>{description}</p>
      </div>

      <div class="button-row">
        <a class="button button-primary" href={primaryHref} target="_blank" rel="noreferrer">{primaryLabel}</a>
        {secondaryLabel && secondaryHref && (
          <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-shell {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(56, 97, 128, 0.12);
    background:
      radial-gradient(circle at top right, rgba(219, 234, 245, 0.8), transparent 35%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 247, 252, 0.9));
    box-shadow: 0 20px 40px -30px var(--color-shadow-strong);
  }

  .cta-shell h2 {
    margin: 0.85rem 0 0.7rem;
    font-family: var(--font-heading);
    font-size: clamp(2.3rem, 5vw, 3.8rem);
    line-height: 0.95;
  }

  .cta-shell p:last-child {
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (min-width: 860px) {
    .cta-shell {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }
</style>