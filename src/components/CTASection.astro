---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow = 'Pronto para começar?',
  title,
  description,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref
} = Astro.props;
---

<section class="section-sm cta-wrapper" id="contato">
  <div class="container">
    <div class="cta-shell reveal">
      <div class="cta-copy">
        <p class="eyebrow">{eyebrow}</p>
        <h2>{title}</h2>
        <p>{description}</p>
      </div>

      <div class="button-row cta-btns">
        <a class="button button-primary" href={primaryHref} target="_blank" rel="noreferrer">
          {primaryLabel}
        </a>
        {secondaryLabel && secondaryHref && (
          <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-shell {
    display: grid;
    gap: 2rem;
    padding: 3rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-teal-border);
    background:
      radial-gradient(ellipse at top right, rgba(58, 191, 173, 0.08), transparent 50%),
      var(--color-surface);
    position: relative;
    overflow: hidden;
  }

  .cta-shell::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-teal), transparent 80%);
  }

  .cta-copy {
    display: grid;
    gap: 0.8rem;
  }

  .cta-copy h2 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .cta-copy p:last-child {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-text-muted);
    max-width: 44rem;
  }

  .cta-btns {
    align-self: center;
  }

  @media (min-width: 860px) {
    .cta-shell {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }

  @media (max-width: 599px) {
    .cta-shell {
      padding: 2rem 1.5rem;
    }
  }
</style>
