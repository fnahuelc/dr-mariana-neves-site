---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import AboutDoctor from '../components/AboutDoctor.astro';
import CannabinoidExplainer from '../components/CannabinoidExplainer.astro';
import ConditionsSection from '../components/ConditionsSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FAQList from '../components/FAQList.astro';
import CTASection from '../components/CTASection.astro';
import { conditions, faqs, siteConfig, stats, steps } from '../data/site';
---

<MainLayout>
  <Hero
    title={siteConfig.heroTitle}
    description={siteConfig.heroDescription}
    primaryLabel={siteConfig.whatsappLabel}
    primaryHref={siteConfig.whatsappUrl}
    secondaryLabel="Conhecer os Tratamentos"
    secondaryHref="#condicoes"
  />

  <Stats items={stats} />

  <AboutDoctor />

  <CannabinoidExplainer />

  <ConditionsSection items={conditions} />

  <HowItWorks steps={steps} />

  <section class="section faq-section" id="faq">
    <div class="container">
      <div class="faq-head reveal">
        <p class="eyebrow">Perguntas Frequentes</p>
        <h2 class="section-title">Respostas para as dúvidas mais comuns.</h2>
        <p class="section-lead">
          O tratamento com canabinóides levanta questões legítimas. Aqui respondemos as principais dúvidas com transparência.
        </p>
      </div>
      <FAQList items={faqs} />
    </div>
  </section>

  <CTASection
    eyebrow="Pronto para dar o próximo passo?"
    title="Agende sua consulta com a Dra. Mariana."
    description="Em uma consulta inicial, a Dra. Mariana avalia seu histórico, explica o tratamento e, se indicado, elabora um protocolo personalizado para o seu caso."
    primaryLabel={siteConfig.whatsappLabel}
    primaryHref={siteConfig.whatsappUrl}
    secondaryLabel={`Enviar e-mail`}
    secondaryHref={`mailto:${siteConfig.email}`}
  />
</MainLayout>

<style>
  .faq-section {
    background: var(--color-surface-muted);
  }

  .faq-head {
    display: grid;
    gap: 1rem;
    margin-bottom: 2.5rem;
    max-width: 680px;
  }
</style>
